{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termif",
  "version": "0.1.0",
  "identifier": "com.termif.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Termif",
        "width": 1100,
        "height": 700,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "maximized": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}