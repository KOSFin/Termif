{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Termif",
        "width": 1100,
        "height": 700,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "maximized": false,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["windowBackground"],
          "state": "active"
        },
        "trafficLightPosition": {
          "x": 14,
          "y": 16
        }
      }
    ]
  }
}
